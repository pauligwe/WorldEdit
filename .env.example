# Required: Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Optional: only needed if you want the 14 uAgents to register on Agentverse.
# Without this, set WORLD_BUILD_DISABLE_UAGENTS=1 to skip the uAgent thread.
AGENTVERSE_API_KEY=

# Optional: skip starting the 14 uAgents (faster local dev). Set to 1 to disable.
WORLD_BUILD_DISABLE_UAGENTS=1
