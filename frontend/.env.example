# Required for next-cloudinary client components (CldImage, CldUploadWidget).
# Find this in your Cloudinary console: Dashboard → Account Details → Cloud name.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Required for the unsigned upload widget. Create one in
# Cloudinary console → Settings → Upload → Upload presets → "Add upload preset".
# Set Signing Mode to "Unsigned".
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Optional: only needed for server-side signed uploads (see app/api/thumbnail).
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
